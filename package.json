{
  "name": "photo-challenge-nodejs",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js rewrite scaffold for Wikimedia Commons Photo Challenge tooling",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json --outDir .test-dist --noEmit false",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "cli": "npm run build --silent && node dist/cli.js",
    "cli:dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "check:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "npm run build:test && node .test-dist/tests/run.js"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-handlebars": "^8.0.1",
    "keytar": "^7.9.0",
    "luxon": "^3.6.1",
    "mwn": "^3.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
