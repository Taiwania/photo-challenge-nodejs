{
  "name": "photo-challenge-nodejs",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js rewrite scaffold for Wikimedia Commons Photo Challenge tooling",
  "main": "dist/server.js",
  "engines": {
    "node": ">=26.5.0 <27",
    "npm": ">=11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json --outDir .test-dist --noEmit false",
    "dev": "tsx watch src/server.ts",
    "dev:nodemon": "nodemon --watch src --ext ts,handlebars,css --exec tsx src/server.ts",
    "start": "node dist/server.js",
    "cli": "npm run build --silent && node dist/cli.js",
    "cli:dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "check:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "npm run build:test && node .test-dist/tests/run.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-handlebars": "^8.0.7",
    "keytar": "^7.9.0",
    "luxon": "^3.7.2",
    "mwn": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
