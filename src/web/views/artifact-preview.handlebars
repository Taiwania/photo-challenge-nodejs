<section class="panel panel-wide">
  <div class="panel-header">
    <div>
      <h1>Artifact Preview</h1>
      <p class="lede"><code>{{fileName}}</code> from job <code>{{job.id}}</code>.</p>
    </div>
    <div class="actions">
      <a href="{{downloadUrl}}">Download</a>
      <a href="/jobs/{{job.id}}/result">Back to result</a>
    </div>
  </div>

  {{#if coreArtifacts.length}}
    <section class="preview-nav-card">
      <h2>Core Outputs</h2>
      <p class="lede">Switch between the main generated pages without leaving preview mode.</p>
      <div class="preview-nav-grid">
        {{#each coreArtifacts}}
          <article class="preview-nav-item {{#if isActive}}preview-nav-item-active{{/if}}">
            <p class="artifact-kicker">{{label}}</p>
            <h3><code>{{name}}</code></h3>
            <p class="artifact-copy">{{description}}</p>
            <div class="preview-nav-actions">
              {{#if isActive}}
                <span class="preview-nav-current">Currently open</span>
              {{else}}
                <a class="preview-nav-link" href="{{previewUrl}}">Open preview</a>
              {{/if}}
              <a class="preview-nav-link preview-nav-link-secondary" href="{{downloadUrl}}">Download</a>
            </div>
          </article>
        {{/each}}
      </div>
    </section>
  {{/if}}

  <pre class="artifact-preview"><code>{{content}}</code></pre>
</section>
